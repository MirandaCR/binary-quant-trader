IQ_EMAIL=your_email@example.com
IQ_PASSWORD=your_password
ACCOUNT_TYPE=PRACTICE
TIMEFRAME=60
ASSETS=EURUSD-OTC,GBPUSD-OTC,EURJPY-OTC
INVESTMENT_AMOUNT=1.0
MAX_DAILY_LOSS_PCT=5.0
MAX_CONSECUTIVE_LOSSES=5
MIN_WIN_RATE=0.55
BACKTEST_PERIODS=150
STRATEGY_EVAL_INTERVAL=300
NEWS_API_KEY=your_newsapi_key
EXPIRATION_MINUTES=1

# AI provider for the multi-agent system: deepseek (default) | openai | gemini | anthropic
AI_PROVIDER=deepseek
AI_API_KEY=your_deepseek_or_other_provider_key
# Optional overrides — leave unset to use the selected provider's default endpoint/model
AI_BASE_URL=
AI_MODEL=
